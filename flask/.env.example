# Copy this file to `.env` (same folder) and fill in real values.
# `.env` is git-ignored — never commit real secrets.
# Used only in development (ENV_PROD=false). In production, the 4 secrets
# below are provided via Docker secrets (/run/secrets/<name>) instead.

# ───────────────────────── Environment ───────────────────────── #
ENV_PROD=false

# ───────────────────────── Required secrets ──────────────────────── #
# Flask session/CSRF signing key - generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=changeme

# https://myaccount.google.com/apppasswords
EMAIL_APP_PASSWORD=changeme

# https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=changeme

# https://twelvedata.com/account/api-keys
TWELVEDATA_API_KEY=changeme

# ───────────────────────── Redis ───────────────────────── #
RATELIMIT_STORAGE_URI=redis://localhost:6379/0

# ───────────────────────── Proxy / Host trust ───────────────────────── #
# Number of reverse-proxy hops in front of Flask (see config.py). Production
# (Cloudflare -> cloudflared -> nginx -> Flask) uses 2 - keep this in sync.
PROXY_TRUSTED_HOP_COUNT=2
EXTERNAL_URL_BASE=http://127.0.0.1:8080

# ───────────────────────── Database reset flags ───────────────────────── #
NEED_TO_RESET_DB_EXCEPT_ACCOUNT=false
NEED_TO_RESET_ALL_DB=false
NEED_TO_RESET_ROLES_PERMISSIONS_TABLES=false

# ───────────────────────── Seeded accounts ───────────────────────── #
CREATE_SEEDED_ACCOUNTS=false
USERNAME_VISITOR=UsernameVisitor
PASSWORD_VISITOR=PasswordVisitor

# ───────────────────────── Auth ───────────────────────── #
USERNAME_SUPER_ADMIN=superadmin