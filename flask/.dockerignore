# ===== Secrets — never bake these into an image =====
.env
.env.*
*.env

# ===== Python =====
**/__pycache__/
**/*.py[cod]
**/*.pyo
**/*.egg-info/
**/*.egg
**/.pytest_cache/
.coverage
htmlcov/
.tox/

# ===== Data / uploads (mounted as volumes, not baked into the image) =====
Data/db/
static/uploads/

# ===== VCS / editor / OS cruft =====
.git/
.gitignore
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db
